# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=Dify Admin
NEXT_PUBLIC_APP_VERSION=0.1.0

# API Configuration
API_TIMEOUT=30000
API_RETRY_TIMES=3

# Authentication
NEXT_PUBLIC_AUTH_ENABLED=true

# CopilotKit (Optional)
NEXT_PUBLIC_COPILOT_ENABLED=false
NEXT_PUBLIC_COPILOT_API_URL=

# AI Models
NEXT_PUBLIC_DEFAULT_MODEL=gpt-4
NEXT_PUBLIC_DEFAULT_TEMPERATURE=0.7

# Feature Flags
NEXT_PUBLIC_ENABLE_WORKFLOWS=true
NEXT_PUBLIC_ENABLE_KNOWLEDGE_BASE=true
NEXT_PUBLIC_ENABLE_MCP=true
NEXT_PUBLIC_ENABLE_AUDIT_LOG=true
